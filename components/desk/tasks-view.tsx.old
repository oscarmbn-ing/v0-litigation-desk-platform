  movimiento: "Movimiento",
  redaccion: "Redacción",
  revision: "Revisión",
  cotizacion: "Cotización",
  gestion: "Gestión",
  comunicacion: "Comunicación",
}

/* ─── Helpers ─── */

function isToday(label: string) {
  const v = label.toLowerCase()
  return v.includes("hoy") || v.includes("ayer")
}

function dueRank(label: string) {
  const v = label.toLowerCase()
  if (v.includes("ayer")) return 0
  if (v.includes("hoy")) return 1
  if (v.includes("manana")) return 2
  return 7
}

function movementCountForClient(task: DeskTask, allTasks: DeskTask[]) {
  if (task.subtype !== "movimiento") return 0
  return allTasks.filter(
    (t) => t.subtype === "movimiento" && t.clientName === task.clientName,
  ).length
}

function formatDueLabel(date: string) {
  const [year, month, day] = date.split("-")
  if (!year || !month || !day) return date
  return `${day}/${month}/${year}`
}

/* ─── Components ─── */

type Props = {
  onOpenClient: (client: Client) => void
}

export function TasksView({ onOpenClient }: Props) {
  const [tasks, setTasks] = useState<DeskTask[]>(initialTasks)
  const [query, setQuery] = useState("")
  const [activeTab, setActiveTab] = useState<TabFilter>("todos")
  const [selectedTaskId, setSelectedTaskId] = useState<string | null>(null)
  const [showProgress, setShowProgress] = useState(true)

  /* Simple Filters for Demo */
  const filtered = useMemo(() => {
    return tasks.filter(t => 
        (activeTab === 'todos' || 
         (activeTab === 'movimiento' && t.subtype === 'movimiento') ||
         (activeTab === 'gestion' && t.subtype !== 'movimiento')
        ) &&
        (t.title.toLowerCase().includes(query.toLowerCase()) || t.clientName.toLowerCase().includes(query.toLowerCase()))
    )
  }, [tasks, query, activeTab])

  const selectedTask = useMemo(
    () => tasks.find((t) => t.id === selectedTaskId) ?? null,
    [tasks, selectedTaskId],
  )

  const handleUpdateTask = (updated: DeskTask) => {
    setTasks(prev => prev.map(t => t.id === updated.id ? updated : t))
  }

  const handleClose = () => setSelectedTaskId(null)

  return (
    <section className="space-y-5">
      {/* ─── Header Stats ─── */}
      {showProgress && (
        <div className="relative rounded-2xl border border-slate-100 bg-white p-5 shadow-sm">
             <button
            onClick={() => setShowProgress(false)}
            className="absolute right-3 top-3 text-slate-400 hover:text-slate-600"
            title="Ocultar progreso"
          >
            <EyeOff className="h-4 w-4" />
          </button>
          <div className="flex items-center gap-4">
            <div className="flex h-12 w-12 items-center justify-center rounded-full bg-[#262262]/10 text-[#262262]">
                <Sparkles className="h-6 w-6" />
            </div>
            <div>
                <p className="text-sm font-bold text-slate-800">¡Buenos días, Fernanda!</p>
                <p className="text-xs text-slate-500">Tienes {tasks.filter(t => t.status === 'pendiente').length} tareas pendientes para hoy.</p>
            </div>
          </div>
        </div>
      )}

      {/* ─── Controls ─── */}
      <div className="flex flex-wrap items-center gap-2">
        <div className="relative flex-1 min-w-[200px]">
            <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" />
            <input 
                className="w-full rounded-xl border border-slate-200 py-2 pl-9 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-[#262262]/20"
                placeholder="Buscar tareas..."
                value={query}
                onChange={e => setQuery(e.target.value)}
            />
        </div>
        <div className="flex gap-1 bg-slate-100 p-1 rounded-xl">
             {(['todos', 'movimiento', 'gestion'] as const).map(tab => (
                 <button
                    key={tab}
                    onClick={() => setActiveTab(tab)}
                    className={cn(
                        "px-3 py-1.5 text-xs font-medium rounded-lg transition-all capitalize",
                        activeTab === tab ? "bg-white shadow-sm text-slate-900" : "text-slate-500 hover:text-slate-700"
                    )}
                 >
                     {tab}
                 </button>
             ))}
        </div>
      </div>

       {/* ─── Task List ─── */}
       <div className="grid gap-3">
          {filtered.map(task => (
              <TaskCard 
                key={task.id} 
                task={task} 
                movementCount={task.movementData ? task.movementData.reduce((acc, c) => acc + c.notebooks.reduce((nAcc, n) => nAcc + n.movements.length, 0), 0) : 0}
                onExecute={() => setSelectedTaskId(task.id)}
              />
          ))}
       </div>

      {/* ─── Advanced Modal ─── */}
      <Dialog open={Boolean(selectedTask)} onOpenChange={(open) => !open && handleClose()}>
        <DialogContent className="max-w-5xl p-0 gap-0 overflow-hidden bg-[#f8f9fc]">
            {selectedTask && (
                selectedTask.subtype === 'movimiento' && selectedTask.movementData ? (
                    <TaskProcessModal 
                        task={selectedTask} 
                        onClose={handleClose} 
                        onUpdate={handleUpdateTask}
                        onOpenClient={onOpenClient}
                    />
                ) : (
                    // Fallback for other tasks (Classic view)
                    <ClassicTaskModal task={selectedTask} onClose={handleClose} />
                )
            )}
        </DialogContent>
      </Dialog>
    </section>
  )
}

/* ─── Sub-Components ─── */

function TaskCard({ task, movementCount, onExecute }: { task: DeskTask, movementCount: number, onExecute: () => void }) {
    return (
      <div 
        className="group relative flex items-start gap-4 rounded-xl border border-slate-200 bg-white p-4 transition-all hover:border-[#262262]/30 hover:shadow-md cursor-pointer"
        onClick={onExecute}
      >
         <div className={cn(
             "h-10 w-10 shrink-0 rounded-full flex items-center justify-center bg-slate-50 text-slate-500 group-hover:bg-[#262262] group-hover:text-white transition-colors",
             task.subtype === 'movimiento' && "bg-blue-50 text-blue-600 group-hover:bg-blue-600"
         )}>
            {task.subtype === 'movimiento' ? <FileText className="h-5 w-5" /> : <CheckCircle2 className="h-5 w-5" />}
         </div>
         <div className="flex-1 min-w-0">
             <div className="flex items-center gap-2 mb-1">
                 <h3 className="font-bold text-slate-800 text-sm truncate">{task.title}</h3>
                 {movementCount > 1 && (
                     <Badge variant="secondary" className="h-5 px-1.5 bg-blue-100 text-blue-700 hover:bg-blue-100">
                         {movementCount}
                     </Badge>
                 )}
                 <span className="text-[10px] uppercase tracking-wider text-slate-400 font-semibold px-2 py-0.5 rounded-md bg-slate-50">
                    {categoryLabel[task.category]}
                 </span>
             </div>
             <p className="text-xs text-slate-500 mb-1">{task.clientName} • {task.caseIds.join(", ")}</p>
             <div className="flex items-center gap-2">
                 <Badge variant="outline" className={cn(
                     "text-[10px] font-normal",
                     isToday(task.dueLabel) ? "border-amber-200 bg-amber-50 text-amber-700" : "text-slate-500"
                 )}>
                    {task.dueLabel}
                 </Badge>
             </div>
         </div>
         <div className="flex flex-col items-end justify-between self-stretch">
             <Button size="sm" className="hidden group-hover:flex bg-[#262262] h-8 text-xs">
                 Ejecutar
             </Button>
         </div>
      </div>
    )
}

function ClassicTaskModal({ task, onClose }: { task: DeskTask, onClose: () => void }) {
    return (
        <div className="p-6">
            <DialogHeader>
                <DialogTitle>{task.title}</DialogTitle>
                <DialogDescription>{task.clientName}</DialogDescription>
            </DialogHeader>
            <div className="py-8 text-center text-slate-500">
                Vista clásica para tareas de tipo {task.subtype}.
                <br/>
                (Implementación simplificada para demo)
            </div>
            <DialogFooter>
                <Button onClick={onClose}>Cerrar</Button>
            </DialogFooter>
        </div>
    )
}

/* ─── The Mission Control Modal ─── */

function TaskProcessModal({ task, onClose, onUpdate, onOpenClient }: { task: DeskTask, onClose: () => void, onUpdate: (t: DeskTask) => void, onOpenClient: (c: Client) => void }) {
    // Logic for traversing cases and notebooks
    const [currentCaseIndex, setCurrentCaseIndex] = useState(0)
    const [currentNotebookIndex, setCurrentNotebookIndex] = useState(0)
    
    // Track reviewed items (caseId-notebookName)
    const [reviewedKeys, setReviewedKeys] = useState<Set<string>>(new Set())

    // Recommendation editing
    const [editRec, setEditRec] = useState<Recommendation | null>(null)
    const [isEditingRec, setIsEditingRec] = useState(false)

    // Summary Mode
    const [isSummaryMode, setIsSummaryMode] = useState(false)

    // Derived Data
    const movementData = task.movementData || []
    const currentCase = movementData[currentCaseIndex]
    const currentNotebook = currentCase?.notebooks[currentNotebookIndex]
    const currentMovements = currentNotebook?.movements || []
    
    // We assume 1 movement per notebook/case for simplicity in UI, but iterating if multiple
    const activeMovement = currentMovements[0]

    const isLastStep = 
        currentCaseIndex === movementData.length - 1 && 
        currentNotebookIndex === currentCase.notebooks.length - 1

    const handleNext = () => {
        // Mark current as reviewed
        if (currentCase && currentNotebook) {
            const key = `${currentCase.caseId}-${currentNotebook.name}`
            setReviewedKeys(prev => new Set(prev).add(key))
        }

        // Logic to move to next
        if (currentNotebookIndex < currentCase.notebooks.length - 1) {
            setCurrentNotebookIndex(prev => prev + 1)
        } else if (currentCaseIndex < movementData.length - 1) {
            setCurrentCaseIndex(prev => prev + 1)
            setCurrentNotebookIndex(0)
        } else {
            // Finished traversal, go to summary
            setIsSummaryMode(true)
        }
    }

    const handleCompleteTask = () => {
        onUpdate({ ...task, status: 'ejecutada' })
        onClose()
    }

    const handleEditRec = (rec: Recommendation) => {
        setEditRec({ ...rec })
        setIsEditingRec(true)
    }

    const handleSaveRec = () => {
        if (!editRec || !task.recommendations) return
        const newRecs = task.recommendations.map(r => r.id === editRec.id ? editRec : r)
        onUpdate({ ...task, recommendations: newRecs })
        setIsEditingRec(false)
        setEditRec(null)
    }

    const handleDeleteRec = (id: string) => {
        if(!task.recommendations) return
        const newRecs = task.recommendations.filter(r => r.id !== id)
        onUpdate({ ...task, recommendations: newRecs })
    }

    const handleAddRec = () => {
        const newRec: Recommendation = {
             id: `new-${Date.now()}`,
             text: "Nueva recomendación",
             dueDate: new Date().toISOString().split('T')[0],
             type: "General"
        }
        onUpdate({
            ...task,
            recommendations: [...(task.recommendations || []), newRec]
        })
    }

    const recTypes = ["Procedimental", "Urgente", "Estratégico", "Administrativo"]

    if (isSummaryMode) {
        return (
            <div className="flex flex-col h-[85vh]">
                 <div className="flex items-center justify-between px-6 py-4 bg-white border-b border-slate-200">
                    <DialogTitle className="text-lg font-bold text-slate-800">Resumen de Acciones</DialogTitle>
                </div>
                <div className="flex-1 p-8 overflow-y-auto bg-[#f8f9fc]">
                    <div className="max-w-2xl mx-auto space-y-8">
                        <div className="text-center space-y-2">
                             <div className="h-16 w-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
                                 <CheckCircle2 className="h-8 w-8" />
                             </div>
                             <h3 className="text-2xl font-bold text-slate-800">Revision completada</h3>
                             <p className="text-slate-500">Has revisado {reviewedKeys.size} cuadernos en total.</p>
                        </div>

                        <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                            <div className="px-6 py-4 border-b border-slate-100 bg-slate-50">
                                <h4 className="font-bold text-slate-700">Recomendaciones generadas</h4>
                            </div>
                            <div className="divide-y divide-slate-100">
                                {task.recommendations?.map(rec => (
                                    <div key={rec.id} className="px-6 py-4 flex items-center justify-between">
                                        <div className="flex items-center gap-3">
                                            <div className={cn("h-2 w-2 rounded-full", rec.accepted ? "bg-green-500" : "bg-slate-300")} />
                                            <div>
                                                <p className="font-medium text-slate-800">{rec.text}</p>
                                                <p className="text-xs text-slate-500">{rec.type || 'General'} • {rec.dueDate}</p>
                                            </div>
                                        </div>
                                        {rec.accepted && <Badge variant="outline" className="text-green-600 border-green-200 bg-green-50">Aceptada</Badge>}
                                    </div>
                                ))}
                                {(!task.recommendations || task.recommendations.length === 0) && (
                                    <div className="px-6 py-8 text-center text-slate-400">
                                        No hay recomendaciones
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
                 <div className="bg-white border-t border-slate-200 px-6 py-4 flex items-center justify-end gap-3">
                    <Button variant="ghost" onClick={() => setIsSummaryMode(false)}>
                        Volver a revisar
                    </Button>
                    <Button className="bg-[#262262] hover:bg-[#1d1a4d] min-w-[140px]" onClick={handleCompleteTask}>
                        Ejecutar Tarea
                    </Button>
                </div>
            </div>
        )
    }

    if (!currentCase) return null

    return (
        <div className="flex flex-col h-[85vh]">
            {/* 1. Header */}
            <div className="flex items-center justify-between px-6 py-4 bg-white border-b border-slate-200">
                <div className="flex items-center gap-4">
                    <div className="h-10 w-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center">
                        <FileText className="h-5 w-5" />
                    </div>
                    <div>
                        <DialogTitle className="text-lg font-bold text-slate-800">
                            {task.title}
                        </DialogTitle>
                        <div className="flex items-center gap-2 text-sm text-slate-500">
                            <span className="font-medium text-slate-700">{task.clientName}</span>
                            <span>•</span>
                            <span className="text-slate-400">Detectado {task.dueLabel}</span>
                        </div>
                    </div>
                </div>
                <div className="flex items-center gap-2">
                    <Button variant="outline" size="sm" onClick={() => onOpenClient({ id: '1', name: task.clientName, email: '', phone: '', casesCount: 2, riskLevel: 'low', tags: [] } as any)}>
                        Ir al radar <Network className="ml-2 h-4 w-4" />
                    </Button>
                </div>
            </div>

            {/* 2. Top Bar: Case Selector & Notebook Tabs */}
            <div className="bg-white border-b border-slate-200 px-6 pt-4 pb-0 flex flex-col gap-4">
                <div className="flex items-center gap-4">
                     <Select 
                        value={currentCaseIndex.toString()} 
                        onValueChange={(v) => {
                            setCurrentCaseIndex(parseInt(v))
                            setCurrentNotebookIndex(0)
                        }}
                    >
                        <SelectTrigger className="w-[300px] font-semibold text-slate-700 border-slate-200 bg-slate-50/50">
                            <SelectValue />
                        </SelectTrigger>
                        <SelectContent>
                            {movementData.map((c, idx) => (
                                <SelectItem key={c.caseId} value={idx.toString()}>
                                    Causa: {c.caseId}
                                </SelectItem>
                            ))}
                        </SelectContent>
                    </Select>
                    
                    <div className="flex-1" />
                    <div className="text-xs font-medium text-slate-400 uppercase tracking-wider">
                        Cuadernos de la causa
                    </div>
                </div>

                <div className="flex gap-6 overflow-x-auto">
                    {currentCase.notebooks.map((nb, idx) => {
                         const isActive = idx === currentNotebookIndex
                         const isReviewed = reviewedKeys.has(`${currentCase.caseId}-${nb.name}`)
                         return (
                             <button
                                key={nb.name}
                                onClick={() => setCurrentNotebookIndex(idx)}
                                className={cn(
                                    "pb-3 text-sm font-medium border-b-2 transition-all flex items-center gap-2",
                                    isActive ? "border-[#262262] text-[#262262]" : "border-transparent text-slate-500 hover:text-slate-700"
                                )}
                             >
                                {nb.name}
                                {isReviewed && <CheckCircle2 className="h-3.5 w-3.5 text-green-500" />}
                             </button>
                         )
                    })}
                </div>
            </div>

            {/* 3. Main Content Grid */}
            <div className="flex-1 overflow-hidden">
                <div className="grid grid-cols-12 h-full">
                    {/* Left Column: Movement & Recommendations */}
                    <div className="col-span-8 bg-[#f8f9fc] p-6 overflow-y-auto">
                         <div className="space-y-6 max-w-4xl mx-auto">
                             
                             {/* Movement Details Card */}
                             <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                                 <div className="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
                                     <div className="flex items-center gap-2">
                                         <Badge variant={activeMovement.movementType === 'resolucion' ? 'default' : 'secondary'} className="uppercase text-[10px]">
                                             {activeMovement.movementType}
                                         </Badge>
                                         <h4 className="font-bold text-slate-800">{activeMovement.name}</h4>
                                     </div>
                                     <span className="text-xs text-slate-400">{activeMovement.date}</span>
                                 </div>
                                 <div className="p-5">
                                     <div className="rounded-lg bg-blue-50/50 border border-blue-100 p-4 mb-4">
                                         <p className="text-sm text-slate-700 leading-relaxed font-medium">
                                             "{activeMovement.summary}"
                                         </p>
                                     </div>
                                     <div className="grid grid-cols-2 gap-4 text-sm text-slate-600">
                                         <div>
                                             <span className="text-slate-400 text-xs uppercase block mb-1">Tribunal</span>
                                             {activeMovement.court}
                                         </div>
                                         <div>
                                             <span className="text-slate-400 text-xs uppercase block mb-1">Acreedor</span>
                                             {activeMovement.creditor}
                                         </div>
                                     </div>
                                 </div>
                             </div>

                             {/* Recommendations Section */}
                             <div>
                                 <div className="flex items-center justify-between mb-3">
                                     <h5 className="font-bold text-slate-800 flex items-center gap-2">
                                         <Sparkles className="h-4 w-4 text-[#262262]" />
                                         Recomendaciones sugeridas
                                     </h5>
                                     <Button size="sm" variant="ghost" className="h-8 text-[#262262]" onClick={handleAddRec}>
                                         <Plus className="h-4 w-4 mr-1" /> Agregar
                                     </Button>
                                 </div>
                                 <div className="space-y-3">
                                     {task.recommendations?.map(rec => (
                                         <div key={rec.id} className={cn(
                                             "bg-white rounded-xl border p-4 transition-all hover:shadow-md",
                                             rec.accepted ? "border-green-200 bg-green-50/30" : "border-slate-200"
                                         )}>
                                             <div className="flex items-start justify-between gap-4">
                                                 <div className="flex-1">
                                                     <div className="flex items-center gap-2 mb-1">
                                                         <span className="text-xs font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-md">
                                                             {rec.type || 'General'}
                                                         </span>
                                                         <span className="flex items-center text-xs text-slate-400">
                                                             <CalendarDays className="h-3 w-3 mr-1" />
                                                             {rec.dueDate}
                                                         </span>
                                                     </div>
                                                     <p className={cn("text-sm font-medium", rec.accepted ? "text-green-800" : "text-slate-800")}>
                                                         {rec.text}
                                                     </p>
                                                 </div>
                                                 <div className="flex items-center gap-1">
                                                     {rec.accepted ? (
                                                         <Badge className="bg-green-100 text-green-700 hover:bg-green-100 border-none gap-1">
                                                             <CheckCircle2 className="h-3 w-3" /> Aceptado
                                                         </Badge>
                                                     ) : (
                                                         <>
                                                            <Button size="icon" variant="ghost" className="h-8 w-8 text-slate-400 hover:text-[#262262]" onClick={() => handleEditRec(rec)}>
                                                                <Edit2 className="h-4 w-4" />
                                                            </Button>
                                                            <Button size="icon" variant="ghost" className="h-8 w-8 text-slate-400 hover:text-red-600" onClick={() => handleDeleteRec(rec.id)}>
                                                                <Trash2 className="h-4 w-4" />
                                                            </Button>
                                                            <Button size="sm" className="bg-[#262262] text-xs h-8" onClick={() => {
                                                                const updated = task.recommendations?.map(r => r.id === rec.id ? { ...r, accepted: true } : r)
                                                                onUpdate({ ...task, recommendations: updated })
                                                            }}>
                                                                Aceptar
                                                            </Button>
                                                         </>
                                                     )}
                                                 </div>
                                             </div>
                                         </div>
                                     ))}
                                 </div>
                             </div>
                         </div>
                    </div>

                    {/* Right Column: Timeline & Context */}
                    <div className="col-span-4 bg-white border-l border-slate-200 p-6 overflow-y-auto">
                        <div className="mb-6">
                            <h5 className="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Línea de tiempo</h5>
                            <div className="relative space-y-0 pl-2">
                                {/* Vertical line */}
                                <div className="absolute left-[15px] top-2 bottom-4 w-0.5 bg-slate-100" />
                                
                                {activeMovement.timeline.map((event, idx) => (
                                    <div key={idx} className="relative flex gap-4 pb-6 last:pb-0 group">
                                        <div className={cn(
                                            "relative z-10 h-7 w-7 rounded-full flex items-center justify-center border-2 bg-white",
                                            idx === 0 ? "border-[#262262] text-[#262262]" : "border-slate-200 text-slate-300"
                                        )}>
                                            <div className={cn("h-2 w-2 rounded-full", idx === 0 ? "bg-[#262262]" : "bg-slate-300")} />
                                        </div>
                                        <div>
                                            <p className={cn("text-xs font-semibold", idx === 0 ? "text-[#262262]" : "text-slate-500")}>
                                                {event.date}
                                            </p>
                                            <p className={cn("text-sm font-bold mt-0.5", idx === 0 ? "text-slate-800" : "text-slate-600")}>
                                                {event.title}
                                            </p>
                                            <div className="flex items-center gap-2 mt-1">
                                                <Badge variant="outline" className="text-[10px] h-5 px-1.5 font-normal text-slate-400 border-slate-200">
                                                    {event.notebook}
                                                </Badge>
                                                {event.risk && (
                                                    <Badge className={cn(
                                                        "text-[10px] h-5 px-1.5 border-none",
                                                        event.risk === 'Crítico' ? "bg-red-50 text-red-600" :
                                                        event.risk === 'Medio' ? "bg-amber-50 text-amber-600" :
                                                        "bg-emerald-50 text-emerald-600"
                                                    )}>
                                                        {event.risk}
                                                    </Badge>
                                                )}
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div className="rounded-xl bg-slate-50 p-4 border border-slate-100">
                             <div className="flex items-center gap-2 mb-3">
                                 <AlertTriangle className="h-4 w-4 text-amber-500" />
                                 <span className="font-bold text-sm text-slate-700">Índice de Riesgo</span>
                             </div>
                             <div className="flex items-center gap-2 mb-2">
                                <div className="h-2 flex-1 rounded-full bg-slate-200 overflow-hidden">
                                     <div className={cn(
                                         "h-full w-[40%]", 
                                         activeMovement.riskIndex === 'Crítico' ? 'bg-red-500 w-[90%]' : 
                                         activeMovement.riskIndex === 'Medio' ? 'bg-amber-500 w-[60%]' :
                                         'bg-emerald-500 w-[20%]'
                                     )} />
                                </div>
                                <span className={cn(
                                    "text-xs font-bold",
                                    activeMovement.riskIndex === 'Crítico' ? 'text-red-600' :
                                    activeMovement.riskIndex === 'Medio' ? 'text-amber-600' :
                                    'text-emerald-600'
                                )}>{activeMovement.riskIndex}</span>
                             </div>
                             <p className="text-xs text-slate-500">
                                 Basado en el historial de resoluciones y tiempos de respuesta.
                             </p>
                        </div>
                    </div>
                </div>
            </div>

            {/* 4. Footer Actions */}
            <div className="bg-white border-t border-slate-200 px-6 py-4 flex items-center justify-between">
                <Button variant="ghost" onClick={onClose} className="text-slate-500 hover:text-slate-800">
                    Cancelar
                </Button>
                <div className="flex items-center gap-3">
                    <Button variant="outline" className="text-slate-600" onClick={() => {}}>
                        Marcar Imposible
                    </Button>
                    <Button 
                        onClick={handleNext} 
                        className="bg-[#262262] hover:bg-[#1d1a4d] min-w-[140px]"
                    >
                        {isLastStep ? "Finalizar Tarea" : (
                           <>
                             Siguiente <ArrowRight className="ml-2 h-4 w-4" />
                           </>
                        )}
                    </Button>
                </div>
            </div>

            {/* Editing Modal Logic (Nested) */}
            {/* Using a simple absolute overlay for "nested" modal feel without battling z-indexes of multiple Dialogs */}
            {isEditingRec && editRec && (
                <div className="absolute inset-0 z-50 flex items-center justify-center bg-black/20 backdrop-blur-sm p-4">
                    <div className="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden animate-in fade-in zoom-in-95 duration-200">
                        <div className="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
                             <h4 className="font-bold text-slate-800">Editar Recomendación</h4>
                             <Button size="icon" variant="ghost" className="h-6 w-6" onClick={() => setIsEditingRec(false)}>
                                 <X className="h-4 w-4" />
                             </Button>
                        </div>
                        <div className="p-5 space-y-4">
                            <div className="space-y-1.5">
                                <Label>Tipo de acción</Label>
                                <Select 
                                    value={editRec.type || 'General'} 
                                    onValueChange={(v) => setEditRec({ ...editRec, type: v })}
                                >
                                    <SelectTrigger>
                                        <SelectValue />
                                    </SelectTrigger>
                                    <SelectContent>
                                        {recTypes.map(t => <SelectItem key={t} value={t}>{t}</SelectItem>)}
                                    </SelectContent>
                                </Select>
                            </div>
                            
                            <div className="space-y-1.5">
                                <Label>Texto de la recomendación</Label>
                                <Textarea 
                                    value={editRec.text}
                                    onChange={(e) => setEditRec({ ...editRec, text: e.target.value })}
                                    className="min-h-[80px]"
                                />
                            </div>

                            <div className="space-y-1.5">
                                <Label>Motivo del cambio (Obligatorio)</Label>
                                <Textarea 
                                    placeholder="Explique por qué se modifica la estrategia..."
                                    value={editRec.reason || ''}
                                    onChange={(e) => setEditRec({ ...editRec, reason: e.target.value })}
                                    className="min-h-[60px]"
                                />
                            </div>

                            <div className="space-y-1.5">
                                <Label>Fecha límite</Label>
                                <Input 
                                    type="date" 
                                    value={editRec.dueDate}
                                    onChange={(e) => setEditRec({ ...editRec, dueDate: e.target.value })}
                                />
                            </div>
                        </div>
                        <div className="px-5 py-4 bg-slate-50 flex justify-end gap-2">
                            <Button variant="ghost" onClick={() => setIsEditingRec(false)}>Cancelar</Button>
                            <Button className="bg-[#262262]" onClick={handleSaveRec} disabled={!editRec.reason}>
                                Guardar Cambios
                            </Button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    )
}
